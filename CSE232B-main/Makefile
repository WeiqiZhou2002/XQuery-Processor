# CSE 232B — XQuery Processor, Milestone 1 (XPath)
#
# Targets:
#   make            generate ANTLR parser + compile everything
#   make parser     only regenerate parser (after editing XPath.g4)
#   make run Q='...'  run a query; example: make run Q='doc("test.xml")/library/book'
#   make clean      delete generated + compiled files

ANTLR_JAR = antlr-4.13.2-complete.jar
CP        = .;$(ANTLR_JAR)
JFLAGS    = -g -encoding UTF-8

# Java sources that YOU write (engine + driver).
HAND_SRCS = Context.java XPathEngine.java XQueryEngine.java Main.java

# Java sources GENERATED by ANTLR from XPath.g4. (XPath — Milestone 1)
XPATH_GEN = XPathLexer.java XPathParser.java XPathVisitor.java XPathBaseVisitor.java

# Java sources GENERATED by ANTLR from XQuery.g4. (XQuery — Milestone 2)
XQUERY_GEN = XQueryLexer.java XQueryParser.java XQueryVisitor.java XQueryBaseVisitor.java

all: classes

# Regenerate the parser/lexer/visitor from the grammar.
$(XPATH_GEN): XPath.g4
	java -jar $(ANTLR_JAR) -visitor -no-listener XPath.g4

$(XQUERY_GEN): XQuery.g4
	java -jar $(ANTLR_JAR) -visitor -no-listener XQuery.g4

parser: $(XPATH_GEN) $(XQUERY_GEN)

# Compile everything into .class files in this directory.
classes: parser
	javac $(JFLAGS) -cp $(CP) $(XPATH_GEN) $(XQUERY_GEN) $(HAND_SRCS)

# Quick run. Override Q on the command line.
Q ?= doc("test.xml")/library/book
run: classes
	java -cp $(CP) Main test.xml query.txt output.xml

clean:
	del /f *.class *.interp *.tokens
	del /f $(XPATH_GEN) $(XQUERY_GEN)

.PHONY: all parser classes run clean
